<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.agentscopea2a.mapper.mysql.MysqlPingMapper">

    <resultMap id="PingResultMap" type="com.agentscopea2a.entity.PingResult">
        <result column="result" property="result"/>
        <result column="source" property="source"/>
    </resultMap>

    <select id="ping" resultMap="PingResultMap">
        SELECT 1 AS result, 'mysql' AS source
    </select>

</mapper>
