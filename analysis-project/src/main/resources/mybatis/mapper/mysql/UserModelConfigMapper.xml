<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.agentscopea2a.mapper.mysql.UserModelConfigMapper">

    <resultMap id="BaseResultMap" type="com.agentscopea2a.entity.UserModelConfig">
        <id column="user_id" property="userId"/>
        <result column="provider" property="provider"/>
        <result column="token" property="token"/>
        <result column="model_name" property="modelName"/>
        <result column="request_url" property="requestUrl"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT user_id, provider, token, model_name, request_url, created_at, updated_at
        FROM user_model_config
        WHERE user_id = #{userId}
    </select>

</mapper>
